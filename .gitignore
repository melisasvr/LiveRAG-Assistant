# .gitignore

# Environment variables
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.venv
venv/
ENV/
env/
pip-log.txt
pip-delete-this-directory.txt

# Data and cache
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# ChromaDB / Vector stores
chroma/
*.chroma
vectorstore/
embeddings/

# Logs
*.log
logs/
*.log.*

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Streamlit
.streamlit/secrets.toml

# Testing
.coverage
htmlcov/
.pytest_cache/
.tox/
.nox/

# Build and distribution
*.mo
*.pot


# Temporary files
tmp/
temp/
*.tmp

# PyInstaller
# Usually .gitignore includes these:
*.manifest
*.spec

